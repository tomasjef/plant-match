<div class="app-page">
  <div class="app-container">
  <div class="page-header">
    <div>
      <p class="page-kicker">Saved collection</p>
      <h1 class="page-title">My Plants</h1>
      <p class="page-subtitle">Plants you have saved from your matches.</p>
    </div>
    <%= link_to "Find a Plant", find_plant_path, class: "btn btn-success rounded-pill px-4" %>
  </div>

  <% if @favorites.any? %>
    <div class="plant-grid">
      <% @favorites.each do |favorite| %>
        <div class="plant-card surface-card">
          <% if favorite.plant.image_url.present? %>
            <%= image_tag favorite.plant.image_url, class: "plant-card-image", alt: favorite.plant.display_name %>
          <% else %>
            <div class="plant-placeholder">Plant</div>
          <% end %>

          <div class="plant-card-body">
            <h2 class="plant-card-title"><%= favorite.plant.display_name %></h2>
            <%= render "plants/plant_tags", plant: favorite.plant %>

            <div class="plant-actions">
              <%= link_to "View Details", plant_path(favorite.plant), class: "btn btn-sm btn-success rounded-pill px-3 py-2" %>
              <%= link_to "Remove",
                          saved_plant_path(favorite),
                          data: { turbo_method: :delete, turbo_confirm: "Remove from My Plants?" },
                          class: "btn btn-sm btn-soft-danger rounded-pill px-3 py-2" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="empty-state surface-card">
      <div class="empty-state-inner">
        <h2 class="h4">No saved plants yet</h2>
        <p class="text-muted mb-4">Answer a few questions and save your favourite plant matches here.</p>
        <%= link_to "Find a Plant", find_plant_path, class: "btn btn-success rounded-pill px-5 py-3" %>
      </div>
    </div>
  <% end %>

  </div>
</div>
