<div class="app-page">
  <div class="app-container">

  <div class="page-header">
    <div>
      <p class="page-kicker">Your results</p>
      <h1 class="page-title">Your Plant Matches</h1>
      <p class="page-subtitle">Here are plants that match your rooms, habits, and preferences.</p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Retake", find_plant_path, class: "btn btn-outline-success rounded-pill px-3" %>
      <% if user_signed_in? %>
        <%= link_to "My Plants", my_plants_path, class: "btn btn-success rounded-pill px-3" %>
      <% else %>
        <%= link_to "Sign up to save plants", new_user_registration_path, class: "btn btn-success rounded-pill px-3" %>
      <% end %>
    </div>
  </div>

  <% if @plants.any? %>
    <div class="plant-grid">
      <% @plants.each do |item| %>
        <% plant = item[:plant] %>

        <div class="plant-card surface-card">
          <% if plant.image_url.present? %>
            <%= image_tag plant.image_url, class: "plant-card-image", alt: plant.name %>
          <% else %>
            <div class="plant-placeholder">Plant</div>
          <% end %>

          <div class="plant-card-body">
            <h2 class="plant-card-title"><%= plant.name %></h2>
            <%= render "plants/plant_tags", plant: plant %>

            <div class="plant-actions">
              <%= link_to "See Details", plant_path(plant), class: "btn btn-sm btn-success rounded-pill px-3 py-2" %>

              <%= button_to save_plant_path(plant), method: :post, class: "btn btn-sm btn-soft-danger rounded-pill px-3 py-2" do %>
                Save Plant
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state surface-card">
      <div class="empty-state-inner">
        <h2 class="h4">No matches found</h2>
        <p class="text-muted">Try adjusting your answers to broaden the match.</p>
        <%= link_to "Try Again", find_plant_path, class: "btn btn-success rounded-pill px-4 mt-3" %>
      </div>
    </div>
  <% end %>

  </div>
</div>
