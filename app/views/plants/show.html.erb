<div class="app-page">
  <div class="app-container">

  <%= link_to "← Back to matches", @back_to_matches_path, class: "back-link" %>

  <div class="row g-4 mt-3">

    <%# LEFT COLUMN — image + pills %>
    <div class="col-md-5">
      <div class="position-relative">
        <%= plant_image @plant, css_class: "detail-image", image_url: @plant.api_image_url.presence || @plant.image_url %>
      </div>

      <div class="mt-3">
        <%= render "plants/plant_tags", plant: @plant %>
      </div>
    </div>

    <div class="col-md-7 ps-md-5">
      <div class="plant-detail-content">
        <div class="plant-detail-header">
          <div>
            <h1 class="page-title"><%= @plant.display_name %></h1>
            <% if @plant.scientific_name.present? %>
              <p class="detail-scientific-name"><%= @plant.scientific_name %></p>
            <% end %>
          </div>

          <%= button_to save_plant_path(@plant), method: :post, class: "btn btn-soft-danger rounded-pill px-4 py-2" do %>
            Save Plant
          <% end %>
        </div>

        <% if @plant_info.present? %>
          <div class="detail-copy"><%= @plant_info.to_s.strip %></div>
        <% else %>
          <p class="detail-empty">Detailed care notes are still being loaded.</p>
        <% end %>
      </div>
    </div>

    <div class="col-12">
      <section class="plant-assistant">
        <% if user_signed_in? %>
          <% quick_questions = [
            "How big will it grow?",
            "Is it air purifying?",
            "How fast does it grow?",
            "Common problems to watch for?"
          ] %>

          <div class="plant-assistant-messages">
            <%= render @chat.messages.recent_first %>
          </div>

          <%= simple_form_for @message,
                              url: plant_assistant_messages_path(@plant),
                              html: { class: "plant-assistant-form" } do |f| %>
            <%= f.input :content,
                        label: false,
                        placeholder: "Ask a follow-up question...",
                        input_html: { class: "plant-assistant-input" } %>
            <%= f.button :submit, "Send", class: "btn btn-success plant-assistant-submit" %>
          <% end %>

          <div class="plant-assistant-prompts">
            <% quick_questions.each do |question| %>
              <%= button_to question,
                            plant_assistant_messages_path(@plant),
                            method: :post,
                            params: { message: { content: question } },
                            class: "plant-assistant-prompt" %>
            <% end %>
          </div>
        <% else %>
          <p class="plant-assistant-note">Log in to ask care questions about this plant.</p>
          <%= link_to "Log in to ask",
                      new_user_session_path,
                      class: "btn btn-outline-success rounded-pill px-4" %>
        <% end %>
      </section>
    </div>
  </div>
  </div>
</div>
