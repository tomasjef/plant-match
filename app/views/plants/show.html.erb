<div class="app-page">
  <div class="app-container">

  <%= link_to "← Find another match", find_plant_path, class: "back-link" %>

  <div class="row g-4 mt-3">

    <%# LEFT COLUMN — image + pills %>
    <div class="col-md-5">
      <div class="position-relative">
        <% if @plant.image_url.present? %>
          <%= image_tag @plant.image_url, class: "detail-image", alt: @plant.name %>
        <% else %>
          <div class="plant-placeholder detail-image">
            Plant
          </div>
        <% end %>
      </div>

      <div class="mt-3">
        <%= render "plants/plant_tags", plant: @plant %>
      </div>
    </div>

    <%# RIGHT COLUMN — name + button + description %>
    <div class="col-md-7 ps-md-5 d-flex flex-column">
      <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
        <h1 class="page-title"><%= @plant.name %></h1>
        <%= button_to save_plant_path(@plant), method: :post, class: "btn btn-soft-danger rounded-pill px-4 py-2" do %>
          Save Plant
        <% end %>
      </div>

      <div class="detail-copy mt-4 surface-card p-4">
        <%= @plant_info || "Coming soon..." %>
      </div>
    </div>

  </div>
  </div>
</div>
