<div class="app-page">
  <div class="app-container">
  <div class="page-header">
    <div>
      <p class="page-kicker">Browse</p>
      <h1 class="page-title">Browse Plants</h1>
      <p class="page-subtitle">A temporary plant library while API-powered recommendations are being built.</p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to "My Plants", my_plants_path, class: "btn btn-outline-success rounded-pill px-3" %>
      <%= link_to "Find a New Plant", find_plant_path, class: "btn btn-success rounded-pill px-3" %>
    </div>
  </div>

  <div class="plant-grid">
    <% @plants.each do |plant| %>
      <div class="plant-card surface-card">
        <% if plant.image_url.present? %>
          <%= image_tag plant.image_url, class: "plant-card-image", alt: plant.display_name %>
        <% else %>
          <div class="plant-placeholder">Plant</div>
        <% end %>

        <div class="plant-card-body">
          <h2 class="plant-card-title"><%= plant.display_name %></h2>
          <%= render "plants/plant_tags", plant: plant %>

          <div class="plant-actions">
            <%= link_to "See Details", plant_path(plant), class: "btn btn-sm btn-success rounded-pill px-3 py-2" %>

            <%= button_to save_plant_path(plant), method: :post, class: "btn btn-sm btn-soft-danger rounded-pill px-3 py-2" do %>
              Save Plant
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  </div>
</div>
