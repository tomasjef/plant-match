<div class="app-page">
  <div class="app-container">

  <div class="row align-items-center justify-content-center g-5">
    <div class="col-md-6">
      <%= image_tag "hero-plant.jpg", class: "img-fluid detail-image", alt: "Plants on a bright shelf" %>
    </div>
    <div class="col-md-6 text-start align-items-center">
      <p class="page-kicker">Plant Match Maker</p>
      <h1 class="display-5 mb-3">
        Find the right plant<br>
        for your home
      </h1>
      <p class="lead text-muted mb-4">Answer a few questions and get plants that fit your rooms, habits, and lifestyle.</p>
      <div class="d-flex flex-wrap gap-3">
        <% if user_signed_in? %>
          <%# Buttons for logged in User %>
          <%= link_to "Find a match", find_plant_path, class: "btn btn-success rounded-pill px-4 py-3" %>
          <%= link_to "My Plants", my_plants_path, class: "btn btn-outline-success rounded-pill px-4 py-3" %>
        <% else %>
          <%# Button for guests %>
          <%= link_to "Find a match", new_user_registration_path, class: "btn btn-success rounded-pill px-5 py-3" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row g-3 align-items-stretch text-center mt-5">
    <div class="col-md-4">
      <div class="surface-card p-4 h-100">
        <p class="page-kicker">01</p>
        <h5>Describe your rooms</h5>
        <p class="text-muted small">Tell us about light, pets, and how much care you want to give.</p>
        <%= image_tag "plant1.jpg", class: "img-fluid rounded mt-3 home-step-image", alt: "Small plant" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card p-4 h-100">
        <p class="page-kicker">02</p>
        <h5>Get tailored matches</h5>
        <p class="text-muted small">See plants that suit your home, routine, and confidence level.</p>
        <%= image_tag "plant2.jpg", class: "img-fluid rounded mt-3 home-step-image", alt: "Potted plant" %>
      </div>
    </div>
    <div class="col-md-4">
      <div class="surface-card p-4 h-100">
        <p class="page-kicker">03</p>
        <h5>Save your favourites</h5>
        <p class="text-muted small">Keep the plants you like in My Plants so you can come back to them later.</p>
        <%= image_tag "plant3.jpg", class: "img-fluid rounded mt-3 home-step-image", alt: "Plant leaves" %>
      </div>
    </div>
  </div>

  <div class="mt-5 text-center mb-4">
    <p class="text-muted small mb-3">Matched around what matters</p>
    <div class="d-flex flex-wrap justify-content-center gap-2">
      <span class="plant-tag">Pet safe</span>
      <span class="plant-tag">Low light</span>
      <span class="plant-tag">Water needs</span>
      <span class="plant-tag">Easy care</span>
      <span class="plant-tag">Room placement</span>
      <span class="plant-tag">Indoor spaces</span>
      <span class="plant-tag">Small rooms</span>
    </div>
  </div>

  </div>
</div>
