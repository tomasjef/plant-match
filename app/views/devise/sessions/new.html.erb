<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5">
      <div class="card auth-card">
        <div class="card-body p-4 p-md-5">
          <div class="text-center mb-4">
            <h1 class="h3 mb-2">Log in</h1>
            <p class="text-muted mb-0">Welcome back to Plant Match Maker.</p>
          </div>

          <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="mb-3">
              <%= f.input :email,
                          required: false,
                          autofocus: true,
                          label_html: { class: "form-label" },
                          input_html: { autocomplete: "email", class: "form-control form-control-lg" } %>
            </div>

            <div class="mb-3">
              <%= f.input :password,
                          required: false,
                          label_html: { class: "form-label" },
                          input_html: { autocomplete: "current-password", class: "form-control form-control-lg" } %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="mb-4">
                <%= f.input :remember_me,
                            as: :boolean,
                            wrapper_html: { class: "form-check" },
                            input_html: { class: "form-check-input" },
                            label_html: { class: "form-check-label" } %>
              </div>
            <% end %>

            <%= f.button :submit, "Log in", class: "btn btn-success btn-lg w-100 rounded-pill" %>
          <% end %>

          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
