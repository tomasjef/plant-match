<div class="app-page">
  <div class="app-container chat-panel">
    <%= link_to "← Back to questionnaire", find_plant_path, class: "back-link" %>

    <div class="page-header">
      <div>
        <p class="page-kicker">Plant assistant</p>
        <h1 class="page-title">Ask About Plants</h1>
        <p class="page-subtitle">Use this space for follow-up questions while the dedicated plant chat is being shaped.</p>
      </div>
    </div>

    <div id="messages"
         class="mb-4"
         data-controller="chat"
         data-chat-target="messages">
      <%= render @chat.messages %>
    </div>

    <div id="new_message_container" class="surface-card p-4">
      <%= simple_form_for @message, url: plant_chat_messages_path(@chat) do |f| %>
        <%= f.input :content,
                    label: "Question",
                    required: true,
                    placeholder: "Type your question...",
                    input_html: { class: "form-control" } %>
        <%= f.button :submit, "Send", class: "btn btn-success rounded-pill px-4" %>
      <% end %>
    </div>
  </div>
</div>
